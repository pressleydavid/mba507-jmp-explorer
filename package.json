{
  "name": "mba507-jmp-explorer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "David Pressley",
  "description": "Interactive JMP 19.1.0 clickpath tree for MBA 507 — Data Driven Managerial Decisions 2.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
